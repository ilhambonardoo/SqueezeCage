generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String    @id @default(cuid())
  nama      String    @db.VarChar(255)
  email     String    @unique
  password  String
  role      Role      @default(OPERATOR)
  image     String?   @db.Text
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  username  String    @unique
  kambing   Kambing[]
}

model Kambing {
  id            String           @id @default(cuid())
  userId        String?
  kode_kambing  String           @unique
  beratAwal     Float
  jenis_kelamin JenisKelamin?
  tgl_lahir     DateTime?
  tgl_Masuk     DateTime         @default(now())
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  beratAkhir    Float
  statusHamil   StatusKehamilan?
  umur          Int
  jenis_hewan   JenisHewan
  imageKey      String?
  imageUrl      String?
  nama          String
  user          User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  riwayatBerat  RiwayatBerat[]
}

model RiwayatBerat {
  id        String   @id @default(cuid())
  berat     Float
  kambingId String
  tgl_cek   DateTime @default(now())
  createdAt DateTime @default(now())
  kambing   Kambing  @relation(fields: [kambingId], references: [id], onDelete: Cascade)
}

enum Role {
  ADMIN
  OPERATOR
}

enum JenisKelamin {
  JANTAN
  BETINA
}

enum StatusKehamilan {
  HAMIL
  TIDAK_HAMIL
}

enum JenisHewan {
  DOMBA
  KAMBING
}
