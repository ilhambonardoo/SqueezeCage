generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String    @id @default(cuid())
  nama      String    @db.VarChar(255)
  email     String    @unique
  password  String
  role      Role      @default(OPERATOR)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  username  String    @unique
  image     String?
  ternakList  Ternak[]
}

model Ternak {
  id            String           @id @default(cuid())
  userId        String?
  kode_hewan    String           @unique
  nama          String
  beratAwal     Float
  jenis_kelamin JenisKelamin?
  tgl_lahir     DateTime?
  tgl_masuk     DateTime         @default(now())
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  beratAkhir    Float
  statusHamil   StatusKehamilan?
  umur          Int
  jenis_hewan   JenisHewan
  sekatId       String?
  sekat         Sekat?      @relation(fields: [sekatId], references: [id], onDelete: SetNull)
  programTernak ProgramTernak?
  imageKey      String?
  imageUrl      String?
  user          User?            @relation(fields: [userId], references: [id])
  riwayatBerat  RiwayatBerat[]
}

model Sekat {
  id          String    @id @default(cuid())
  kodeSekat   String    @unique
  keteranganSekat KeteranganSekat @default(INDIVIDU)

  kandangId   String
  kandang     Kandang   @relation(fields: [kandangId], references: [id], onDelete: Cascade)

  ternakList Ternak[]

  createdAt   DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}


model Kandang {
  id        String    @id @default(cuid())
  nama      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  sekatList Sekat[]
}

model RiwayatBerat {
  id        String   @id @default(cuid())
  berat     Float
  ternakId String
  tgl_cek   DateTime @default(now())
  createdAt DateTime @default(now())
  ternak   Ternak  @relation(fields: [ternakId], references: [id], onDelete: Cascade)
}


enum Role {
  ADMIN
  OPERATOR
}

enum JenisKelamin {
  JANTAN
  BETINA
}

enum StatusKehamilan {
  HAMIL
  TIDAK_HAMIL
}

enum JenisHewan {
  DOMBA
  KAMBING
}

enum ProgramTernak {
  FATTENING
  BREEDING
}

enum KeteranganSekat {
  INDIVIDU
  KOLONI
}